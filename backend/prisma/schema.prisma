generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════

enum Role {
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum OrderType {
  PURCHASE
  SALE
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CREDIT
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRY_SOON
  OVERDUE_PAYMENT
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ══════════════════════════════════════════════════════
// 1. USER
// ══════════════════════════════════════════════════════
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  phone     String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  auditLogs    AuditLog[]
  transfers    StockTransfer[]

  @@map("users")
}

// ══════════════════════════════════════════════════════
// 2. WAREHOUSE
// ══════════════════════════════════════════════════════
model Warehouse {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?
  city      String?
  country   String   @default("Pakistan")
  phone     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  products       Product[]
  transfersFrom  StockTransfer[] @relation("TransferFrom")
  transfersTo    StockTransfer[] @relation("TransferTo")

  @@map("warehouses")
}

// ══════════════════════════════════════════════════════
// 3. CATEGORY
// ══════════════════════════════════════════════════════
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  color       String   @default("#4f46e5")
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  subCategories SubCategory[]

  @@map("categories")
}

// ══════════════════════════════════════════════════════
// 4. SUB_CATEGORY (EER - Specialization of Category)
// ══════════════════════════════════════════════════════
model SubCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())

  products    Product[]

  @@unique([name, categoryId])
  @@map("sub_categories")
}

// ══════════════════════════════════════════════════════
// 5. SUPPLIER
// ══════════════════════════════════════════════════════
model Supplier {
  id           String         @id @default(uuid())
  name         String
  email        String?        @unique
  phone        String?
  address      String?
  city         String?
  country      String?
  taxId        String?
  creditLimit  Decimal        @db.Decimal(12,2) @default(0)
  paymentTerms Int            @default(30)
  status       SupplierStatus @default(ACTIVE)
  rating       Int?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  products      Product[]
  orders        Order[]
  payments      Payment[]
  contacts      SupplierContact[]

  @@map("suppliers")
}

// ══════════════════════════════════════════════════════
// 6. SUPPLIER_CONTACT
// ══════════════════════════════════════════════════════
model SupplierContact {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name        String
  designation String?
  email       String?
  phone       String?
  isPrimary   Boolean  @default(false)

  @@map("supplier_contacts")
}

// ══════════════════════════════════════════════════════
// 7. PRODUCT
// ══════════════════════════════════════════════════════
model Product {
  id             String        @id @default(uuid())
  name           String
  sku            String        @unique
  barcode        String?       @unique
  description    String?
  costPrice      Decimal       @db.Decimal(12,2)
  sellingPrice   Decimal       @db.Decimal(12,2)
  quantity       Int           @default(0)
  reorderLevel   Int           @default(10)
  maxStockLevel  Int           @default(500)
  unit           String        @default("units")
  weight         Decimal?      @db.Decimal(8,3)
  expiryDate     DateTime?
  imageUrl       String?
  status         ProductStatus @default(ACTIVE)
  taxRate        Decimal       @db.Decimal(5,2) @default(0)

  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  warehouseId   String?
  warehouse     Warehouse?   @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems     OrderItem[]
  alerts         StockAlert[]
  priceHistory   PriceHistory[]
  transferItems  StockTransferItem[]

  @@map("products")
}

// ══════════════════════════════════════════════════════
// 8. PRICE_HISTORY
// ══════════════════════════════════════════════════════
model PriceHistory {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldPrice     Decimal  @db.Decimal(12,2)
  newPrice     Decimal  @db.Decimal(12,2)
  changedAt    DateTime @default(now())
  changedBy    String?
  reason       String?

  @@map("price_history")
}

// ══════════════════════════════════════════════════════
// 9. ORDER
// ══════════════════════════════════════════════════════
model Order {
  id           String      @id @default(uuid())
  orderNumber  String      @unique
  type         OrderType
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12,2) @default(0)
  discount     Decimal     @db.Decimal(12,2) @default(0)
  taxAmount    Decimal     @db.Decimal(12,2) @default(0)
  notes        String?
  orderDate    DateTime    @default(now())
  expectedDate DateTime?
  completedAt  DateTime?

  userId      String
  user        User      @relation(fields: [userId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payment  Payment?
  shipment Shipment?

  @@map("orders")
}

// ══════════════════════════════════════════════════════
// 10. ORDER_ITEM
// ══════════════════════════════════════════════════════
model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(12,2)
  discount  Decimal @db.Decimal(12,2) @default(0)
  subtotal  Decimal @db.Decimal(12,2)
  notes     String?

  @@map("order_items")
}

// ══════════════════════════════════════════════════════
// 11. PAYMENT
// ══════════════════════════════════════════════════════
model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  amount        Decimal       @db.Decimal(12,2)
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(PENDING)
  referenceNo   String?
  paidAt        DateTime?
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  @@map("payments")
}

// ══════════════════════════════════════════════════════
// 12. SHIPMENT
// ══════════════════════════════════════════════════════
model Shipment {
  id             String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  trackingNumber String?
  carrier        String?
  shippedAt      DateTime?
  expectedAt     DateTime?
  deliveredAt    DateTime?
  status         String   @default("pending")
  address        String?
  notes          String?

  @@map("shipments")
}

// ══════════════════════════════════════════════════════
// 13. STOCK_ALERT
// ══════════════════════════════════════════════════════
model StockAlert {
  id         String        @id @default(uuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       AlertType
  severity   AlertSeverity @default(MEDIUM)
  message    String
  isRead     Boolean       @default(false)
  isResolved Boolean       @default(false)
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?

  @@map("stock_alerts")
}

// ══════════════════════════════════════════════════════
// 14. STOCK_TRANSFER
// ══════════════════════════════════════════════════════
model StockTransfer {
  id            String         @id @default(uuid())
  transferNo    String         @unique
  fromWarehouse Warehouse      @relation("TransferFrom", fields: [fromId], references: [id])
  fromId        String
  toWarehouse   Warehouse      @relation("TransferTo", fields: [toId], references: [id])
  toId          String
  status        TransferStatus @default(PENDING)
  requestedById String
  requestedBy   User           @relation(fields: [requestedById], references: [id])
  notes         String?
  createdAt     DateTime       @default(now())
  completedAt   DateTime?

  items StockTransferItem[]

  @@map("stock_transfers")
}

// ══════════════════════════════════════════════════════
// 15. STOCK_TRANSFER_ITEM
// ══════════════════════════════════════════════════════
model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Int

  @@map("stock_transfer_items")
}

// ══════════════════════════════════════════════════════
// 16. CUSTOMER
// ══════════════════════════════════════════════════════
model Customer {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  phone        String?
  address      String?
  city         String?
  country      String?
  creditLimit  Decimal  @db.Decimal(12,2) @default(0)
  totalPurchases Decimal @db.Decimal(12,2) @default(0)
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("customers")
}

// ══════════════════════════════════════════════════════
// 17. AUDIT_LOG
// ══════════════════════════════════════════════════════
model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  tableName  String
  recordId   String?
  oldValues  String?
  newValues  String?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════
// 18. DISCOUNT_RULE
// ══════════════════════════════════════════════════════
model DiscountRule {
  id           String   @id @default(uuid())
  name         String
  description  String?
  discountType String   @default("percentage")
  value        Decimal  @db.Decimal(8,2)
  minQuantity  Int?
  minAmount    Decimal? @db.Decimal(12,2)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("discount_rules")
}

// ══════════════════════════════════════════════════════
// 19. REPORT
// ══════════════════════════════════════════════════════
model Report {
  id          String   @id @default(uuid())
  title       String
  type        String
  parameters  String?
  generatedAt DateTime @default(now())
  generatedBy String?
  filePath    String?

  @@map("reports")
}

// ══════════════════════════════════════════════════════
// 20. PRODUCT_TAG
// ══════════════════════════════════════════════════════
model ProductTag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  tagAssignments ProductTagAssignment[]

  @@map("product_tags")
}

// ══════════════════════════════════════════════════════
// 21. PRODUCT_TAG_ASSIGNMENT (Junction)
// ══════════════════════════════════════════════════════
model ProductTagAssignment {
  productId String
  tagId     String
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([productId, tagId])
  @@map("product_tag_assignments")
}

// ══════════════════════════════════════════════════════
// 22. REORDER_REQUEST
// ══════════════════════════════════════════════════════
model ReorderRequest {
  id          String   @id @default(uuid())
  productId   String
  productName String
  sku         String
  currentQty  Int
  requestedQty Int
  supplierId  String?
  supplierName String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@map("reorder_requests")
}
