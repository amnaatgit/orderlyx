{
    "name": "orderlyx-backend",
    "version": "2.0.0",
    "main": "src/server.js",
    "scripts": {
          "dev": "nodemon src/server.js",
          "start": "node src/server.js",
          "postinstall": "prisma generate && prisma db push --accept-data-loss && node prisma/seed.js",
          "db:generate": "prisma generate",
          "db:push": "prisma db push",
          "db:seed": "node prisma/seed.js",
          "db:studio": "prisma studio"
    },
    "dependencies": {
          "@prisma/client": "^5.7.0",
          "bcryptjs": "^2.4.3",
          "cors": "^2.8.5",
          "dotenv": "^16.3.1",
          "express": "^4.18.2",
          "jsonwebtoken": "^9.0.2",
          "prisma": "^5.22.0"
    },
    "devDependencies": {
          "nodemon": "^3.0.2"
    }
}
